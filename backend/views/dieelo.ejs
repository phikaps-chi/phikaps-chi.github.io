<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Die ELO</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #2a2a2a 100%);
            color: #ffd700;
            min-height: 100vh;
            padding: 1rem;
            padding-bottom: 5rem;
        }
        .container { max-width: 1000px; margin: 0 auto; }
        
        .header { text-align: center; margin-bottom: 2rem; position: relative; }
        .title { font-size: 2rem; font-weight: 300; margin-bottom: 0.5rem; }
        
        .card {
            background: linear-gradient(135deg, rgba(0, 0, 0, 0.8) 0%, rgba(20, 20, 20, 0.9) 100%);
            border: 2px solid #ffd700;
            border-radius: 15px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 8px 32px rgba(255, 215, 0, 0.1);
        }
        
        .summary-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 1rem; text-align: center;
        }
        .stat-box {
            background: rgba(255, 215, 0, 0.05); padding: 1rem; border-radius: 10px;
        }
        .stat-value { font-size: 1.8rem; font-weight: bold; margin-bottom: 0.3rem; }
        .stat-label { font-size: 0.8rem; opacity: 0.8; text-transform: uppercase; letter-spacing: 1px; }
        
        h2 { font-size: 1.5rem; font-weight: 300; margin-bottom: 1rem; border-bottom: 1px solid rgba(255, 215, 0, 0.3); padding-bottom: 0.5rem; }
        
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; text-align: left; }
        th, td { padding: 0.8rem; border-bottom: 1px solid rgba(255, 215, 0, 0.2); }
        th { font-weight: 600; color: rgba(255, 215, 0, 0.8); text-transform: uppercase; font-size: 0.85rem; cursor: pointer; }
        th:hover { color: #ffd700; }
        tr:hover { background: rgba(255, 215, 0, 0.05); }
        
        .btn {
            background: #ffd700; color: #1a1a1a; border: none; padding: 0.6rem 1.2rem;
            border-radius: 25px; font-weight: 600; cursor: pointer; transition: all 0.3s ease;
        }
        .btn:hover { background: transparent; color: #ffd700; border: 2px solid #ffd700; transform: translateY(-2px); }
        .btn-small { padding: 0.3rem 0.6rem; font-size: 0.8rem; }
        .btn-danger { background: transparent; border: 1px solid #ff4444; color: #ff4444; }
        .btn-danger:hover { background: #ff4444; color: white; }
        
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(5px);
            display: none; justify-content: center; align-items: center; z-index: 1000;
        }
        .modal {
            background: #1a1a1a; border: 2px solid #ffd700; border-radius: 15px;
            padding: 2rem; width: 90%; max-width: 500px; max-height: 90vh; overflow-y: auto;
        }
        .form-group { margin-bottom: 1rem; }
        .form-group label { display: block; margin-bottom: 0.4rem; font-size: 0.9rem; }
        .form-control {
            width: 100%; padding: 0.8rem; background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 215, 0, 0.3); border-radius: 8px; color: white;
        }
        .form-control:focus { outline: none; border-color: #ffd700; }
        
        .flex-between { display: flex; justify-content: space-between; align-items: center; }
        .gap-2 { gap: 0.5rem; }
        
        .match-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 215, 0, 0.2);
            border-radius: 10px;
            padding: 1rem;
            margin-bottom: 1rem;
            transition: transform 0.2s;
        }
        .match-card:hover {
            border-color: rgba(255, 215, 0, 0.5);
        }
        .match-header {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            color: rgba(255, 215, 0, 0.7);
            margin-bottom: 0.8rem;
            border-bottom: 1px solid rgba(255, 215, 0, 0.1);
            padding-bottom: 0.5rem;
        }
        .match-teams {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }
        .match-team {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.6rem;
            border-radius: 6px;
            background: rgba(0, 0, 0, 0.3);
        }
        .match-team.winner {
            border-left: 3px solid #ffd700;
            background: rgba(255, 215, 0, 0.08);
        }
        .team-name { font-weight: 600; font-size: 0.95rem; }
        .team-label { font-size: 0.7rem; opacity: 0.6; text-transform: uppercase; margin-bottom: 0.2rem; }
        .match-score { font-weight: bold; color: #ffd700; font-size: 0.9rem; }
        .match-actions {
            display: flex;
            justify-content: flex-end;
            gap: 0.5rem;
        }

        .loader {
            border: 4px solid rgba(255, 215, 0, 0.3); border-top: 4px solid #ffd700;
            border-radius: 50%; width: 30px; height: 30px; animation: spin 1s linear infinite;
            margin: 2rem auto;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        .fab {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            width: 60px;
            height: 60px;
            background-color: #ffd700;
            color: #1a1a1a;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 2rem;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(255, 215, 0, 0.4);
            cursor: pointer;
            z-index: 100;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            text-decoration: none;
            border: none;
        }
        .fab:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 20px rgba(255, 215, 0, 0.6);
        }

        /* Mobile Optimizations */
        @media (max-width: 600px) {
            .modal {
                padding: 1.5rem;
                width: 95%;
            }
            .modal h2 {
                font-size: 1.3rem;
            }
            .modal .flex-between {
                flex-direction: column;
                gap: 1rem;
            }
            .modal .flex-between .btn {
                width: 100%;
            }
            /* Stack Team A and Team B */
            .team-container {
                flex-direction: column;
                gap: 0 !important;
            }
            /* Stack Score Type and Remaining */
            .score-container {
                flex-direction: column;
                gap: 0 !important;
            }
            
            /* Table optimizations */
            th, td {
                padding: 0.6rem 0.4rem;
                font-size: 0.85rem;
            }
            .stat-value {
                font-size: 1.5rem;
            }
            .fab {
                bottom: 1.5rem;
                right: 1.5rem;
                width: 50px;
                height: 50px;
                font-size: 1.8rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <% if (position && position.includes('Chi')) { %>
            <button class="btn btn-small" style="position: absolute; top: 0; right: 0; background: rgba(255, 215, 0, 0.1); border: 1px solid #ffd700; color: #ffd700; font-size: 0.7rem;" onclick="recalculateStats()" id="recalc-btn">
                🔄 Recalculate
            </button>
            <% } %>
            <h1 class="title">Die ELO</h1>
            <p>Track your stats and house rankings</p>
            <div style="display: flex; justify-content: center; gap: 1rem; margin-top: 1rem;">
                <button class="btn btn-small" style="background: rgba(255, 215, 0, 0.1); border: 1px solid #ffd700; color: #ffd700;" onclick="document.getElementById('info-modal').style.display = 'flex'">
                    ℹ️ How ELO is Calculated
                </button>
                <button class="btn btn-small" style="background: rgba(255, 215, 0, 0.1); border: 1px solid #ffd700; color: #ffd700;" onclick="document.getElementById('tutorial-modal').style.display = 'flex'">
                    📖 Tutorial
                </button>
            </div>
        </div>

        <div class="card">
            <h2>Your Profile</h2>
            <div id="profile-loader" class="loader"></div>
            <div id="profile-content" class="summary-grid" style="display: none;">
                <div class="stat-box">
                    <div class="stat-value" id="my-elo">-</div>
                    <div class="stat-label">ELO</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value" id="my-rank">-</div>
                    <div class="stat-label">Rank</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value" id="my-record">-</div>
                    <div class="stat-label">W - L</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value" id="my-winpct">-</div>
                    <div class="stat-label">Win %</div>
                </div>
            </div>
        </div>

        <div class="card">
            <h2>House Rankings</h2>
            <div class="table-responsive">
                <table id="rankings-table">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Player</th>
                            <th>ELO</th>
                            <th>W-L</th>
                            <th>Win %</th>
                            <th>Games</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Populated by JS -->
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card" id="pending-disputes-card" style="display: none; border-color: #ff9900;">
            <h2 style="color: #ff9900; border-bottom-color: rgba(255, 153, 0, 0.3);">Pending Disputes</h2>
            <div id="pending-disputes-container">
                <!-- Populated by JS -->
            </div>
        </div>

        <div class="card">
            <h2>My History</h2>
            <div id="history-container">
                <!-- Populated by JS -->
            </div>
        </div>
    </div>

    <button class="fab" onclick="openGameModal()">+</button>

    <!-- Add/Edit Game Modal -->
    <div class="modal-overlay" id="game-modal">
        <div class="modal">
            <h2 id="modal-title">Log a Game</h2>
            <form id="game-form" onsubmit="submitGame(event)">
                <input type="hidden" id="game-id">
                
                <div class="team-container" style="display: flex; gap: 1rem;">
                    <div style="flex: 1;">
                        <h3>Team A</h3>
                        <div class="form-group">
                            <label>Player 1</label>
                            <select class="form-control" id="a-p1" required>
                                <option value="">Select...</option>
                                <option value="FOH">FOH</option>
                                <option value="Alumn">Alumn</option>
                                <% contacts.forEach(c => { %>
                                    <option value="<%= c %>"><%= c %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Player 2</label>
                            <select class="form-control" id="a-p2" required>
                                <option value="">Select...</option>
                                <option value="FOH">FOH</option>
                                <option value="Alumn">Alumn</option>
                                <% contacts.forEach(c => { %>
                                    <option value="<%= c %>"><%= c %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div style="flex: 1;">
                        <h3>Team B</h3>
                        <div class="form-group">
                            <label>Player 1</label>
                            <select class="form-control" id="b-p1" required>
                                <option value="">Select...</option>
                                <option value="FOH">FOH</option>
                                <option value="Alumn">Alumn</option>
                                <% contacts.forEach(c => { %>
                                    <option value="<%= c %>"><%= c %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Player 2</label>
                            <select class="form-control" id="b-p2" required>
                                <option value="">Select...</option>
                                <option value="FOH">FOH</option>
                                <option value="Alumn">Alumn</option>
                                <% contacts.forEach(c => { %>
                                    <option value="<%= c %>"><%= c %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Winning Team</label>
                    <select class="form-control" id="winner" required>
                        <option value="A">Team A</option>
                        <option value="B">Team B</option>
                    </select>
                </div>

                <div class="score-container" style="display: flex; gap: 1rem;">
                    <div class="form-group" style="flex: 1;">
                        <label>Game Type</label>
                        <select class="form-control" id="score-type" required>
                            <option value="halves">Halves</option>
                            <option value="quarters">Quarters</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label id="remaining-label">Remaining Halves</label>
                        <input type="number" class="form-control" id="remaining" min="1" max="10" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Drink</label>
                    <select class="form-control" id="drink-type" required onchange="toggleOtherDrink()">
                        <option value="beer">Beer</option>
                        <option value="wine">Wine</option>
                        <option value="water">Water</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                
                <div class="form-group" id="other-drink-group" style="display: none;">
                    <label>Specify Drink</label>
                    <input type="text" class="form-control" id="other-drink-input" placeholder="What are you drinking?">
                </div>

                <div class="flex-between" style="margin-top: 2rem;">
                    <button type="button" class="btn btn-danger" onclick="closeModal('game-modal')">Cancel</button>
                    <button type="submit" class="btn" id="save-game-btn">Save Game</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Info Modal -->
    <div class="modal-overlay" id="info-modal">
        <div class="modal">
            <h2 style="border-bottom: 1px solid rgba(255, 215, 0, 0.3); padding-bottom: 0.5rem; margin-bottom: 1rem;">How ELO is Calculated</h2>
            <div style="font-size: 0.9rem; line-height: 1.5; color: rgba(255,255,255,0.9); margin-bottom: 1.5rem;">
                <p style="margin-bottom: 0.8rem;">The ranking system uses a modified version of the standard Chess ELO formula.</p>
                <ul style="margin-left: 1.5rem; margin-bottom: 0.8rem;">
                    <li style="margin-bottom: 0.4rem;"><strong>Base Rating:</strong> All new players start at <strong>1000 ELO</strong>.</li>
                    <li style="margin-bottom: 0.4rem;"><strong>Team Rating:</strong> A team's ELO is the exact average of its two players' individual ELOs.</li>
                    <li style="margin-bottom: 0.4rem;"><strong>Win Probability:</strong> The system calculates the expected probability of winning based on the ELO difference: <br><code style="background: rgba(0,0,0,0.5); padding: 2px 4px; border-radius: 4px; display: inline-block; margin-top: 4px; color: #ffd700;">P(Win) = 1 / (1 + 10^((OpponentELO - YourELO) / 400))</code></li>
                    <li style="margin-bottom: 0.4rem;"><strong>The K-Factor (Stakes):</strong> This determines the maximum possible points you can win or lose in a single game.
                        <ul style="margin-left: 1.5rem; margin-top: 0.2rem;">
                            <li><strong>Quarters:</strong> Base K = 48</li>
                            <li><strong>Halves:</strong> Base K = 72 (1.5x multiplier)</li>
                        </ul>
                    </li>
                    <li style="margin-bottom: 0.4rem;"><strong>Margin of Victory:</strong> The more halves/quarters you win by, the bigger the points swing. For every additional point remaining beyond 1, the ELO swing increases by <strong>20%</strong>.</li>
                    <li style="margin-bottom: 0.4rem;"><strong>Drink Modifier:</strong> To limit ELO farming, playing with Water reduces the stakes by <strong>85%</strong> (0.15x multiplier).</li>
                    <li style="margin-bottom: 0.4rem;"><strong>The Point Swing:</strong> The actual points gained or lost is calculated as:<br><code style="background: rgba(0,0,0,0.5); padding: 2px 4px; border-radius: 4px; display: inline-block; margin-top: 4px; color: #ffd700;">Point Swing = K * MarginMultiplier * DrinkMultiplier * (Outcome - P(Win))</code><br><em style="opacity: 0.8; font-size: 0.8rem;">(Where Outcome is 1 for a win and 0 for a loss)</em></li>
                </ul>
                <p style="background: rgba(255, 215, 0, 0.1); padding: 0.8rem; border-radius: 8px; border-left: 3px solid #ffd700;"><strong>TL;DR:</strong> Beating a team with a much higher ELO than yours (an upset) will reward you with significantly more points than beating a lower-rated team. Playing with Halves increases the stakes by 50%, winning by a larger margin boosts your points even more, but playing with Water cuts your points by 85%.</p>
            </div>
            <div style="text-align: right;">
                <button class="btn" onclick="closeModal('info-modal')">Got it</button>
            </div>
        </div>
    </div>

    <!-- Tutorial Modal -->
    <div class="modal-overlay" id="tutorial-modal">
        <div class="modal">
            <h2 style="border-bottom: 1px solid rgba(255, 215, 0, 0.3); padding-bottom: 0.5rem; margin-bottom: 1rem;">How to Use Die ELO</h2>
            <div style="font-size: 0.9rem; line-height: 1.5; color: rgba(255,255,255,0.9); margin-bottom: 1.5rem;">
                <p style="margin-bottom: 0.8rem;">Welcome to the house Die ELO tracker! Here is a quick guide on how to log your games and climb the ranks.</p>
                
                <h3 style="color: #ffd700; font-size: 1rem; margin-top: 1rem; margin-bottom: 0.4rem;">1. Logging a Game</h3>
                <p style="margin-bottom: 0.8rem;">Click the big gold <strong>"+"</strong> button in the bottom right corner of the screen. Fill out the form with the players on Team A and Team B, select the winner, the game type (Halves or Quarters), how many halves/quarters were remaining, and what you were drinking.</p>

                <h3 style="color: #ffd700; font-size: 1rem; margin-top: 1rem; margin-bottom: 0.4rem;">2. Non-House Players</h3>
                <p style="margin-bottom: 0.8rem;">If you are playing with someone who isn't in the house dropdown, you can select <strong>"FOH"</strong> (Friend of House) or <strong>"Alumn"</strong>. These placeholder players do not have their own ELO tracked, but the system will still calculate the ELO change for the active house brothers based on the game.</p>

                <h3 style="color: #ffd700; font-size: 1rem; margin-top: 1rem; margin-bottom: 0.4rem;">3. The Duplicate Warning</h3>
                <p style="margin-bottom: 0.8rem;">To prevent people from double-logging the same game, the system checks if a game with the exact same players and score was logged in the last 2 hours. If it detects a match, it will show you a <strong>Duplicate Warning</strong>. If you actually just played a rematch with the exact same result, you can click "Yes, Log It" to force the submission.</p>

                <h3 style="color: #ffd700; font-size: 1rem; margin-top: 1rem; margin-bottom: 0.4rem;">4. Editing a Game</h3>
                <p style="margin-bottom: 0.8rem;">Made a mistake logging a game? Any of the <strong>4 players</strong> involved can edit it within <strong>2 minutes</strong> of its creation. Just click the green <strong>"Edit"</strong> button that appears next to the game in <strong>My History</strong>. After 2 minutes, the Edit button disappears and changes must go through the dispute process instead.</p>

                <h3 style="color: #ffd700; font-size: 1rem; margin-top: 1rem; margin-bottom: 0.4rem;">5. Disputes</h3>
                <p style="margin-bottom: 0.8rem;">Think a game result is wrong? In <strong>My History</strong>, click the <strong>"Dispute"</strong> button on the game in question. You can propose an <strong>edit</strong> (change the winner, score, or drink) or propose a <strong>deletion</strong>.</p>
                <p style="margin-bottom: 0.8rem;"><strong>Important:</strong> While a dispute is pending, <strong>all 4 players</strong> in that game will have their ELO set to <strong>0</strong> until it is resolved.</p>
                <p style="margin-bottom: 0.8rem;">A player from the <strong>opposing team</strong> will see the dispute in a <strong>"Pending Disputes"</strong> section and can <strong>Accept</strong> or <strong>Reject</strong> it. Once resolved, all ELOs are recalculated from scratch.</p>
            </div>
            <div style="text-align: right;">
                <button class="btn" onclick="closeModal('tutorial-modal')">Got it</button>
            </div>
        </div>
    </div>

    <!-- Dispute Modal -->
    <div class="modal-overlay" id="dispute-modal">
        <div class="modal">
            <h2 id="dispute-modal-title">Dispute This Game</h2>
            <input type="hidden" id="dispute-game-id">
            <input type="hidden" id="dispute-type" value="edit">

            <div id="dispute-original-summary" style="background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px; margin-bottom: 1rem; font-size: 0.85rem;"></div>

            <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
                <button class="btn btn-small" id="dispute-edit-tab" onclick="setDisputeType('edit')" style="flex:1;">Propose Edit</button>
                <button class="btn btn-small btn-danger" id="dispute-delete-tab" onclick="setDisputeType('delete')" style="flex:1;">Propose Deletion</button>
            </div>

            <div id="dispute-edit-fields">
                <div class="form-group">
                    <label>Winning Team</label>
                    <select class="form-control" id="dispute-winner">
                        <option value="A">Team A</option>
                        <option value="B">Team B</option>
                    </select>
                </div>
                <div class="score-container" style="display: flex; gap: 1rem;">
                    <div class="form-group" style="flex: 1;">
                        <label>Game Type</label>
                        <select class="form-control" id="dispute-score-type">
                            <option value="halves">Halves</option>
                            <option value="quarters">Quarters</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Remaining</label>
                        <input type="number" class="form-control" id="dispute-remaining" min="1" max="10">
                    </div>
                </div>
                <div class="form-group">
                    <label>Drink</label>
                    <select class="form-control" id="dispute-drink-type">
                        <option value="beer">Beer</option>
                        <option value="wine">Wine</option>
                        <option value="water">Water</option>
                        <option value="other">Other</option>
                    </select>
                </div>
            </div>

            <div id="dispute-delete-confirm" style="display: none; text-align: center; padding: 1rem; background: rgba(255, 68, 68, 0.1); border: 1px solid #ff4444; border-radius: 8px; margin-bottom: 1rem;">
                <p style="color: #ff4444; font-weight: 600;">You are requesting this game be deleted.</p>
                <p style="font-size: 0.85rem; opacity: 0.8; margin-top: 0.5rem;">A player from the opposing team must approve this action.</p>
            </div>

            <p style="font-size: 0.8rem; opacity: 0.7; margin-bottom: 1rem;">⚠️ While the dispute is pending, all 4 players in this game will have their ELO set to 0. A player from the opposing team must accept or reject it.</p>

            <div class="flex-between" style="margin-top: 1rem;">
                <button class="btn btn-danger" onclick="closeModal('dispute-modal')">Cancel</button>
                <button class="btn" id="submit-dispute-btn" onclick="submitDispute()">Submit Dispute</button>
            </div>
        </div>
    </div>

    <!-- Duplicate Warning Modal -->
    <div class="modal-overlay" id="duplicate-modal">
        <div class="modal">
            <h2>Possible Duplicate Detected</h2>
            <p style="margin-bottom: 1rem;">A very similar game was logged recently. Are you sure this is a new game?</p>
            <div id="duplicate-details" style="background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px; margin-bottom: 1rem; font-size: 0.9rem;"></div>
            <div class="flex-between">
                <button class="btn btn-danger" onclick="closeModal('duplicate-modal')">Cancel</button>
                <button class="btn" id="force-submit-btn" onclick="forceSubmitGame()">Yes, Log It</button>
            </div>
        </div>
    </div>

    <script>
        window.myName = "<%= name %>";
        window.sessionId = "<%= sessionId %>";
        window.pendingGameData = null;

        async function loadData() {
            try {
                const [statsRes, gamesRes, disputesRes] = await Promise.all([
                    fetch(`/api/die/stats?session_id=${window.sessionId}`),
                    fetch(`/api/die/games?session_id=${window.sessionId}`),
                    fetch(`/api/die/disputes?session_id=${window.sessionId}`)
                ]);
                
                const stats = await statsRes.json();
                const games = await gamesRes.json();
                const disputes = await disputesRes.json();
                
                if (stats.error || stats.message) {
                    console.error('Stats error:', stats);
                    return;
                }
                
                window.allDisputes = Array.isArray(disputes) ? disputes : [];
                
                renderProfile(stats);
                renderRankings(stats);
                renderHistory(games, window.allDisputes);
                renderPendingDisputes(games, window.allDisputes);
                
                document.getElementById('profile-loader').style.display = 'none';
                document.getElementById('profile-content').style.display = 'grid';
            } catch (e) {
                console.error('Error loading data', e);
            }
        }

        function renderProfile(stats) {
            const myStat = stats.find(s => s.player_name === window.myName);
            if (myStat) {
                document.getElementById('my-elo').textContent = myStat.ELO || '-';
                document.getElementById('my-rank').textContent = myStat.rank ? `#${myStat.rank}` : '-';
                document.getElementById('my-record').textContent = `${myStat.wins || 0} - ${myStat.losses || 0}`;
                
                const w = parseInt(myStat.wins || 0);
                const l = parseInt(myStat.losses || 0);
                const total = w + l;
                const pct = total > 0 ? Math.round((w / total) * 100) : 0;
                document.getElementById('my-winpct').textContent = `${pct}%`;
            }
        }

        function renderRankings(stats) {
            const tbody = document.querySelector('#rankings-table tbody');
            tbody.innerHTML = '';
            
            stats.forEach(s => {
                const w = parseInt(s.wins || 0);
                const l = parseInt(s.losses || 0);
                const total = w + l;
                const pct = total > 0 ? Math.round((w / total) * 100) : 0;
                const isDisputed = s.rank === '-' || String(s.ELO) === '0';
                
                const tr = document.createElement('tr');
                if (s.player_name === window.myName) tr.style.background = 'rgba(255, 215, 0, 0.1)';
                if (isDisputed) tr.style.opacity = '0.4';
                
                tr.innerHTML = `
                    <td>${isDisputed ? '⚠️' : s.rank}</td>
                    <td>${s.player_name}${isDisputed ? ' <span style="font-size:0.7rem;color:#ff9900;">(disputed)</span>' : ''}</td>
                    <td><strong>${isDisputed ? '0' : s.ELO}</strong></td>
                    <td>${w}-${l}</td>
                    <td>${pct}%</td>
                    <td>${s.games_played}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        window._editTimers = [];

        function renderHistory(games, disputes) {
            const container = document.getElementById('history-container');
            container.innerHTML = '';
            window._editTimers.forEach(t => clearTimeout(t));
            window._editTimers = [];
            
            if (!games || games.length === 0) {
                container.innerHTML = '<p style="text-align:center; opacity:0.6; padding: 1rem;">No games logged yet.</p>';
                return;
            }
            
            disputes = disputes || [];
            const pendingDisputeGameIds = new Set(disputes.filter(d => d.status === 'pending').map(d => d.game_id));
            
            games.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
            
            games.forEach((g) => {
                const date = new Date(g.timestamp).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
                
                const isA = g.winning_team === 'A';
                const teamA = `${g.team_a_player_1 || '?'} & ${g.team_a_player_2 || '?'}`;
                const teamB = `${g.team_b_player_1 || '?'} & ${g.team_b_player_2 || '?'}`;
                const hasPendingDispute = pendingDisputeGameIds.has(g.game_id);
                
                const card = document.createElement('div');
                card.className = 'match-card';
                if (hasPendingDispute) card.style.borderColor = '#ff9900';
                
                const elapsed = Date.now() - new Date(g.timestamp).getTime();
                const editable = elapsed < 120000;
                
                let actionHtml;
                if (hasPendingDispute) {
                    actionHtml = '<span style="background:rgba(255,153,0,0.15);color:#ff9900;padding:0.3rem 0.6rem;border-radius:12px;font-size:0.8rem;font-weight:600;border:1px solid #ff9900;">⏳ Dispute Pending</span>';
                } else {
                    let editBtnHtml = '';
                    if (editable) {
                        const editId = 'edit-btn-' + g.game_id;
                        editBtnHtml = `<button id="${editId}" class="btn btn-small" style="background:rgba(0,200,100,0.1);border:1px solid #00c864;color:#00c864;" onclick='editGame(${JSON.stringify(g).replace(/'/g, "&#39;")})'>Edit</button>`;
                        const remaining = 120000 - elapsed;
                        const timer = setTimeout(() => {
                            const btn = document.getElementById(editId);
                            if (btn) btn.remove();
                        }, remaining);
                        window._editTimers.push(timer);
                    }
                    actionHtml = editBtnHtml + `<button class="btn btn-small" style="background:rgba(255,153,0,0.1);border:1px solid #ff9900;color:#ff9900;" onclick='disputeGame(${JSON.stringify(g).replace(/'/g, "&#39;")})'>Dispute</button>`;
                }
                
                card.innerHTML = `
                    <div class="match-header">
                        <span>${date}</span>
                        <span>${g.drink_type ? g.drink_type.toUpperCase() : 'BEER'}</span>
                    </div>
                    <div class="match-teams">
                        <div class="match-team ${isA ? 'winner' : ''}">
                            <div>
                                <div class="team-label">Team A ${isA ? '👑' : ''}</div>
                                <div class="team-name" style="${isA ? 'color:#ffd700;' : ''}">${teamA}</div>
                            </div>
                            ${isA ? `<div class="match-score">${g.winner_remaining} ${g.score_type} Remaining</div>` : ''}
                        </div>
                        <div class="match-team ${!isA ? 'winner' : ''}">
                            <div>
                                <div class="team-label">Team B ${!isA ? '👑' : ''}</div>
                                <div class="team-name" style="${!isA ? 'color:#ffd700;' : ''}">${teamB}</div>
                            </div>
                            ${!isA ? `<div class="match-score">${g.winner_remaining} ${g.score_type} Remaining</div>` : ''}
                        </div>
                    </div>
                    <div class="match-actions">${actionHtml}</div>
                `;
                container.appendChild(card);
            });
        }

        function openGameModal() {
            document.getElementById('game-form').reset();
            document.getElementById('game-id').value = '';
            document.getElementById('modal-title').textContent = 'Log a Game';
            document.getElementById('save-game-btn').textContent = 'Save Game';
            document.getElementById('other-drink-group').style.display = 'none';
            document.getElementById('game-modal').style.display = 'flex';
        }

        function toggleOtherDrink() {
            const drinkType = document.getElementById('drink-type').value;
            const otherGroup = document.getElementById('other-drink-group');
            const otherInput = document.getElementById('other-drink-input');
            
            if (drinkType === 'other') {
                otherGroup.style.display = 'block';
                otherInput.required = true;
            } else {
                otherGroup.style.display = 'none';
                otherInput.required = false;
                otherInput.value = '';
            }
        }

        function disputeGame(g) {
            document.getElementById('dispute-game-id').value = g.game_id;
            
            const teamA = `${g.team_a_player_1 || '?'} & ${g.team_a_player_2 || '?'}`;
            const teamB = `${g.team_b_player_1 || '?'} & ${g.team_b_player_2 || '?'}`;
            const winnerLabel = g.winning_team === 'A' ? teamA : teamB;
            document.getElementById('dispute-original-summary').innerHTML = `
                <strong style="color:#ffd700;">Original Game</strong><br>
                <span style="opacity:0.9;">Team A:</span> ${teamA}<br>
                <span style="opacity:0.9;">Team B:</span> ${teamB}<br>
                <span style="opacity:0.9;">Winner:</span> Team ${g.winning_team} (${winnerLabel})<br>
                <span style="opacity:0.9;">Score:</span> ${g.winner_remaining} ${g.score_type} remaining &middot; ${(g.drink_type || 'beer').toUpperCase()}
            `;
            
            document.getElementById('dispute-winner').value = g.winning_team;
            document.getElementById('dispute-score-type').value = g.score_type;
            document.getElementById('dispute-remaining').value = g.winner_remaining;
            document.getElementById('dispute-drink-type').value = 
                ['beer','wine','water','other'].includes(g.drink_type) ? g.drink_type : 'other';
            
            setDisputeType('edit');
            document.getElementById('dispute-modal').style.display = 'flex';
        }

        function editGame(g) {
            document.getElementById('game-form').reset();
            document.getElementById('game-id').value = g.game_id;
            document.getElementById('modal-title').textContent = 'Edit Game';
            document.getElementById('save-game-btn').textContent = 'Save Changes';
            document.getElementById('a-p1').value = g.team_a_player_1 || '';
            document.getElementById('a-p2').value = g.team_a_player_2 || '';
            document.getElementById('b-p1').value = g.team_b_player_1 || '';
            document.getElementById('b-p2').value = g.team_b_player_2 || '';
            document.getElementById('winner').value = g.winning_team || 'A';
            document.getElementById('score-type').value = g.score_type || 'halves';
            document.getElementById('remaining').value = g.winner_remaining || '';
            const drink = (g.drink_type || 'beer').toLowerCase();
            if (['beer', 'wine', 'water', 'other'].includes(drink)) {
                document.getElementById('drink-type').value = drink;
            } else {
                document.getElementById('drink-type').value = 'other';
                document.getElementById('other-drink-input').value = g.drink_type || '';
                document.getElementById('other-drink-group').style.display = 'block';
            }
            toggleOtherDrink();
            document.getElementById('game-modal').style.display = 'flex';
        }

        function setDisputeType(type) {
            document.getElementById('dispute-type').value = type;
            const editFields = document.getElementById('dispute-edit-fields');
            const deleteConfirm = document.getElementById('dispute-delete-confirm');
            const editTab = document.getElementById('dispute-edit-tab');
            const deleteTab = document.getElementById('dispute-delete-tab');
            
            if (type === 'edit') {
                editFields.style.display = 'block';
                deleteConfirm.style.display = 'none';
                editTab.style.background = '#ffd700';
                editTab.style.color = '#1a1a1a';
                editTab.style.border = 'none';
                deleteTab.style.background = 'transparent';
                deleteTab.style.color = '#ff4444';
                deleteTab.style.border = '1px solid #ff4444';
            } else {
                editFields.style.display = 'none';
                deleteConfirm.style.display = 'block';
                editTab.style.background = 'rgba(255,215,0,0.1)';
                editTab.style.color = '#ffd700';
                editTab.style.border = '1px solid #ffd700';
                deleteTab.style.background = '#ff4444';
                deleteTab.style.color = 'white';
                deleteTab.style.border = 'none';
            }
        }

        async function submitDispute() {
            const btn = document.getElementById('submit-dispute-btn');
            btn.disabled = true;
            btn.textContent = 'Submitting...';
            
            try {
                const disputeType = document.getElementById('dispute-type').value;
                const payload = {
                    game_id: document.getElementById('dispute-game-id').value,
                    dispute_type: disputeType,
                };
                
                if (disputeType === 'edit') {
                    payload.winning_team = document.getElementById('dispute-winner').value;
                    payload.score_type = document.getElementById('dispute-score-type').value;
                    payload.winner_remaining = document.getElementById('dispute-remaining').value;
                    payload.drink_type = document.getElementById('dispute-drink-type').value;
                }
                
                const res = await fetch(`/api/die/disputes?session_id=${window.sessionId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                
                const result = await res.json();
                if (!res.ok) {
                    alert(result.error || 'Failed to submit dispute');
                    return;
                }
                
                closeModal('dispute-modal');
                loadData();
            } catch (e) {
                console.error(e);
                alert('Error submitting dispute.');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Submit Dispute';
            }
        }

        async function resolveDisputeAction(disputeId, resolution) {
            if (!confirm(`Are you sure you want to ${resolution === 'accepted' ? 'ACCEPT' : 'REJECT'} this dispute?`)) return;
            
            try {
                const res = await fetch(`/api/die/disputes/${disputeId}/resolve?session_id=${window.sessionId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ resolution })
                });
                
                const result = await res.json();
                if (!res.ok) {
                    alert(result.error || 'Failed to resolve dispute');
                    return;
                }
                
                loadData();
            } catch (e) {
                console.error(e);
                alert('Error resolving dispute.');
            }
        }

        function renderPendingDisputes(games, disputes) {
            const container = document.getElementById('pending-disputes-container');
            const card = document.getElementById('pending-disputes-card');
            container.innerHTML = '';
            
            const pending = (disputes || []).filter(d => d.status === 'pending');
            
            const myActionable = pending.filter(d => {
                const gameData = (games || []).find(g => g.game_id === d.game_id);
                if (!gameData) return false;
                const opposingTeam = d.disputer_team === 'A' ? 'B' : 'A';
                const opposingPlayers = opposingTeam === 'A'
                    ? [gameData.team_a_player_1, gameData.team_a_player_2]
                    : [gameData.team_b_player_1, gameData.team_b_player_2];
                return opposingPlayers.includes(window.myName);
            });
            
            if (myActionable.length === 0) {
                card.style.display = 'none';
                return;
            }
            
            card.style.display = 'block';
            
            myActionable.forEach(d => {
                const gameData = (games || []).find(g => g.game_id === d.game_id);
                
                const div = document.createElement('div');
                div.style.cssText = 'background:rgba(255,153,0,0.05);border:1px solid rgba(255,153,0,0.3);border-radius:10px;padding:1rem;margin-bottom:1rem;';
                
                let originalInfo = '';
                if (gameData) {
                    const teamA = `${gameData.team_a_player_1 || '?'} & ${gameData.team_a_player_2 || '?'}`;
                    const teamB = `${gameData.team_b_player_1 || '?'} & ${gameData.team_b_player_2 || '?'}`;
                    originalInfo = `<div style="font-size:0.85rem;margin-bottom:0.5rem;">
                        <strong>Game:</strong> ${teamA} vs ${teamB}<br>
                        <strong>Result:</strong> Team ${gameData.winning_team} won &middot; ${gameData.winner_remaining} ${gameData.score_type} &middot; ${(gameData.drink_type || 'beer').toUpperCase()}
                    </div>`;
                }
                
                let proposedInfo = '';
                if (d.dispute_type === 'delete') {
                    proposedInfo = '<div style="color:#ff4444;font-weight:600;font-size:0.9rem;">🗑️ Requesting game deletion</div>';
                } else {
                    proposedInfo = `<div style="font-size:0.85rem;color:#ff9900;">
                        <strong>Proposed:</strong> Team ${d.proposed_winning_team} wins &middot; ${d.proposed_winner_remaining} ${d.proposed_score_type} &middot; ${(d.proposed_drink_type || 'beer').toUpperCase()}
                    </div>`;
                }
                
                div.innerHTML = `
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
                        <span style="font-weight:600;color:#ff9900;">Dispute by ${d.disputed_by} (Team ${d.disputer_team})</span>
                        <span style="font-size:0.75rem;opacity:0.6;">${new Date(d.timestamp).toLocaleDateString()}</span>
                    </div>
                    ${originalInfo}
                    ${proposedInfo}
                    <div style="display:flex;gap:0.5rem;justify-content:flex-end;margin-top:1rem;">
                        <button class="btn btn-small btn-danger" onclick="resolveDisputeAction('${d.dispute_id}', 'rejected')">Reject</button>
                        <button class="btn btn-small" onclick="resolveDisputeAction('${d.dispute_id}', 'accepted')">Accept</button>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function closeModal(id) {
            document.getElementById(id).style.display = 'none';
        }

        async function submitGame(e) {
            e.preventDefault();
            
            const submitBtn = document.getElementById('save-game-btn');
            const originalText = submitBtn.textContent;
            submitBtn.disabled = true;
            submitBtn.textContent = 'Saving...';
            
            const gameId = document.getElementById('game-id').value;
            const isEdit = !!gameId;
            
            try {
                let drinkType = document.getElementById('drink-type').value;
                if (drinkType === 'other') {
                    drinkType = document.getElementById('other-drink-input').value.trim();
                }
                
                const data = {
                    team_a_player_1: document.getElementById('a-p1').value,
                    team_a_player_2: document.getElementById('a-p2').value,
                    team_b_player_1: document.getElementById('b-p1').value,
                    team_b_player_2: document.getElementById('b-p2').value,
                    winning_team: document.getElementById('winner').value,
                    score_type: document.getElementById('score-type').value,
                    winner_remaining: document.getElementById('remaining').value,
                    drink_type: drinkType,
                };
                
                if (isEdit) {
                    const res = await fetch(`/api/die/games/${gameId}?session_id=${window.sessionId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const result = await res.json();
                    if (!res.ok) {
                        alert(result.error || 'Failed to update game');
                        return;
                    }
                    closeModal('game-modal');
                    loadData();
                } else {
                    const res = await fetch(`/api/die/games?session_id=${window.sessionId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    
                    if (!res.ok) {
                        console.error('Failed to save game:', await res.text());
                        alert('Error saving game. Please try again.');
                        return;
                    }
                    
                    const result = await res.json();
                    
                    if (result.duplicate) {
                        window.pendingGameData = data;
                        document.getElementById('duplicate-details').innerHTML = `
                            Teams: ${result.game.team_a_player_1} & ${result.game.team_a_player_2} vs ${result.game.team_b_player_1} & ${result.game.team_b_player_2}<br>
                            Winner: Team ${result.game.winning_team} (${result.game.winner_remaining} ${result.game.score_type})<br>
                            Time: ${new Date(result.game.timestamp).toLocaleString()}
                        `;
                        document.getElementById('duplicate-modal').style.display = 'flex';
                    } else {
                        closeModal('game-modal');
                        loadData();
                    }
                }
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = originalText;
            }
        }

        async function forceSubmitGame() {
            if (!window.pendingGameData) return;
            
            const forceBtn = document.getElementById('force-submit-btn');
            forceBtn.disabled = true;
            forceBtn.textContent = 'Saving...';
            
            try {
                window.pendingGameData.force_submit = true;
                
                await fetch(`/api/die/games?session_id=${window.sessionId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(window.pendingGameData)
                });
                
                closeModal('duplicate-modal');
                closeModal('game-modal');
                loadData();
            } finally {
                forceBtn.disabled = false;
                forceBtn.textContent = 'Yes, Log It';
            }
        }


        // Initial load
        loadData();

        let pollInterval = setInterval(loadData, 60000);
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                clearInterval(pollInterval);
                pollInterval = null;
            } else {
                loadData();
                pollInterval = setInterval(loadData, 60000);
            }
        });

        // Dynamic Remaining Label
        document.getElementById('score-type').addEventListener('change', function(e) {
            const label = document.getElementById('remaining-label');
            if (e.target.value === 'halves') {
                label.textContent = 'Remaining Halves';
            } else {
                label.textContent = 'Remaining Quarters';
            }
        });

        async function recalculateStats() {
            if (!confirm('Are you sure you want to completely recalculate all player stats from the game ledger? This may take a few seconds.')) return;
            
            const btn = document.getElementById('recalc-btn');
            if (btn) {
                btn.disabled = true;
                btn.textContent = '🔄...';
            }
            
            try {
                const res = await fetch(`/api/die/recalculate?session_id=${window.sessionId}`, { method: 'POST' });
                if (!res.ok) throw new Error('Failed to recalculate');
                
                alert('Stats successfully recalculated!');
                loadData();
            } catch (e) {
                console.error(e);
                alert('Error recalculating stats.');
            } finally {
                if (btn) {
                    btn.disabled = false;
                    btn.textContent = '🔄 Recalculate';
                }
            }
        }
    </script>
</body>
</html>
